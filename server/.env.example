# ============================================================
# CONFIGURACION DEL SERVIDOR OECE-IA
# Copia este archivo como .env y completa los valores
# ============================================================

# Clave API de Google Gemini
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-XXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo de Gemini para el chat (LLM)
GEMINI_MODEL=gemini-2.0-flash

# Modelo de Gemini para embeddings (RAG)
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Puerto del servidor (default: 8000)
PORT=8000

# Host del servidor
HOST=0.0.0.0

# Permitir CORS desde estos dominios (separados por coma)
# En producción, reemplaza * por tu dominio real
ALLOWED_ORIGINS=*

# Directorio para guardar la base de datos vectorial
CHROMA_DB_PATH=./chroma_db

# Directorio donde colocas los documentos a ingestar
DATA_DIR=./data
