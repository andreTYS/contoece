# ============================================================
# CONFIGURACION DEL SERVIDOR OECE-IA
# Copia este archivo como .env y completa los valores
# ============================================================

# Clave API de Anthropic (Claude)
# Obtén tu clave en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo de Claude a usar
CLAUDE_MODEL=claude-sonnet-4-6

# Puerto del servidor (default: 8000)
PORT=8000

# Host del servidor
HOST=0.0.0.0

# Permitir CORS desde estos dominios (separados por coma)
# En producción, reemplaza * por tu dominio real
ALLOWED_ORIGINS=*

# Directorio para guardar la base de datos vectorial
CHROMA_DB_PATH=./chroma_db

# Directorio donde colocas los documentos a ingestar
DATA_DIR=./data
