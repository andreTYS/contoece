<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  INSTRUCCIONES:
  1. Ve a https://console.firebase.google.com → tu proyecto
  2. Agrega una app iOS con bundle ID: com.oece.contrataciones
  3. Descarga el archivo GoogleService-Info.plist real
  4. Reemplaza ESTE archivo (renómbralo quitando el .example)
  5. Colócalo en: ios/Runner/GoogleService-Info.plist
  6. En Xcode, agrégalo al target Runner

  NUNCA subas el archivo real al repositorio público.
-->
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>TU_CLIENT_ID.apps.googleusercontent.com</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>com.googleusercontent.apps.TU_CLIENT_ID</string>
	<key>API_KEY</key>
	<string>TU_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>TU_SENDER_ID</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.oece.contrataciones</string>
	<key>PROJECT_ID</key>
	<string>TU_PROJECT_ID</string>
	<key>STORAGE_BUCKET</key>
	<string>TU_PROJECT_ID.appspot.com</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>1:TU_SENDER_ID:ios:TU_APP_ID</string>
</dict>
</plist>
